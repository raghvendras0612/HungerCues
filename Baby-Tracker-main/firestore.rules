rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasFamilyMemberIds() {
      return request.resource.data.memberIds is list;
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
    }

    match /users/{userId} {
      allow read, update, delete: if ownsUserDoc(userId);
      allow create: if ownsUserDoc(userId);

      match /{document=**} {
        allow read, write: if ownsUserDoc(userId);
      }
    }

    match /families/{familyId} {
      allow create: if signedIn()
        && hasFamilyMemberIds()
        && request.auth.uid in request.resource.data.memberIds;
      allow read, update, delete: if isFamilyMember(familyId);

      match /{document=**} {
        allow read, write: if isFamilyMember(familyId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
