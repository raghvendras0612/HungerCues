# =========================
# Database
# =========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/baby_tracker

# =========================
# Firebase
# =========================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json
EXPO_PUBLIC_FIREBASE_API_KEY=your-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-web-app-id

# =========================
# Cloudflare R2
# =========================
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=baby-tracker

# =========================
# Gemma AI Service
# =========================
GEMMA_API_URL=http://localhost:8080
GEMMA_API_KEY=your-gemma-api-key

# =========================
# Backend
# =========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development
